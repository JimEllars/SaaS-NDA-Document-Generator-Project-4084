# Environment Variables Configuration
# These values should be securely stored in the Cloudflare Pages / Workers dashboard.

# Public Stripe Publishable Key (used by frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Feature flag for Web3 bypass
VITE_ENABLE_WEB3=false

# Secret Token for Edge Execution (used by Cloudflare Worker to authenticate with AXiM Core API)
AXIM_SERVICE_KEY=axim_svc_...

# Base URL for local development to point to sandbox API proxy (leave empty in production to use relative worker paths)
VITE_PAYMENT_API_URL=
